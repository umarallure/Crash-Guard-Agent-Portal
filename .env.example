# Browser-safe configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_ALOWARE_DIALER_URL=https://app.aloware.com

# Local historical-import authentication. Configure the same value as a
# Supabase Edge Function secret; never prefix secrets with VITE_.
ALOWARE_WEBHOOK_SECRET=generate_at_least_32_random_characters
# Must exactly match Aloware Account > General Settings. It is the source
# timezone used only when Aloware sends a timestamp without an offset.
ALOWARE_ACCOUNT_TIMEZONE=America/Los_Angeles
