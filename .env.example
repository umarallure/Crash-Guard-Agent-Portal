# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Monday.com API Configuration
# Get your API token from: https://[your-account].monday.com/admin/integrations/api
VITE_MONDAY_API_TOKEN=your_monday_api_token_here

# Monday.com Board Configuration
# Your production board ID: 8595002703 (already set as default)
# Only override this if you want to use a different board for testing
# VITE_MONDAY_BOARD_ID=8595002703

# Slack Configuration
# Set this to your specific workspace URL for direct loading, e.g. https://app.slack.com/client/T00000000
# Leave blank to default to https://app.slack.com
VITE_SLACK_WORKSPACE_URL=https://app.slack.com

# Aloware Dialer Configuration
# Get your API token from: Aloware Dashboard > Integrations > API
VITE_ALOWARE_API_TOKEN=your_aloware_api_token_here
# Optional: Custom Aloware URL (defaults to https://app.aloware.com)
# VITE_ALOWARE_DIALER_URL=https://app.aloware.com
